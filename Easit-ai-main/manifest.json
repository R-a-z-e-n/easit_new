{
  "manifest_version": 3,
  "name": "Easit.ai - Hallucination-Free Voice Assistant",
  "version": "1.0.0",
  "description": "The world's first hallucination-free voice assistant. Grounded in real-time data, verified by logic.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://*.vercel.app/*",
    "https://*.google.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
